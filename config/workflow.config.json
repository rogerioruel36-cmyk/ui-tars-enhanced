{
  "version": "1.0.0",
  "engine": "puppeteer",
  "browser": {
    "headless": true,
    "viewport": {
      "width": 1920,
      "height": 1080
    },
    "timeout": 30000,
    "userAgent": null
  },
  "logging": {
    "level": "info",
    "output": "./logs"
  },
  "workspace": {
    "path": "./workspace",
    "cleanup": true
  },
  "reports": {
    "path": "./reports",
    "format": "html"
  },
  "retry": {
    "maxAttempts": 3,
    "delay": 1000,
    "backoff": "exponential"
  },
  "skills": {
    "autoLoad": true,
    "path": "./skills"
  }
}
