{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ui-tars.example.com/workflow.schema.json",
  "title": "UI-TARS Workflow Template Schema",
  "description": "JSON Schema for UI-TARS workflow template DSL defining stages, actions, and skills structure",
  "type": "object",
  "required": ["version", "name", "stages"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Workflow template version following semver"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Workflow template name"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Workflow template description"
    },
    "metadata": {
      "$ref": "#/definitions/metadata"
    },
    "config": {
      "$ref": "#/definitions/workflowConfig"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/stage"
      },
      "description": "Ordered list of workflow stages"
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/skill"
      },
      "description": "Skills required by this workflow"
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/variable"
      },
      "description": "Workflow-level variables"
    },
    "errors": {
      "$ref": "#/definitions/errorHandling"
    }
  },
  "definitions": {
    "metadata": {
      "type": "object",
      "properties": {
        "author": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "modified": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "enum": ["automation", "scraping", "testing", "reporting", "research", "custom"]
        }
      }
    },
    "workflowConfig": {
      "type": "object",
      "properties": {
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Global workflow timeout in milliseconds"
        },
        "retry": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Number of retries on failure"
        },
        "continueOnError": {
          "type": "boolean",
          "description": "Whether to continue if a stage fails"
        },
        "parallel": {
          "type": "boolean",
          "description": "Enable parallel stage execution"
        },
        "browser": {
          "$ref": "#/definitions/browserConfig"
        }
      }
    },
    "browserConfig": {
      "type": "object",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["puppeteer", "playwright", "auto"]
        },
        "headless": {
          "type": "boolean"
        },
        "viewport": {
          "$ref": "#/definitions/viewport"
        },
        "userAgent": {
          "type": "string"
        }
      }
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 320
        },
        "height": {
          "type": "integer",
          "minimum": 240
        }
      }
    },
    "stage": {
      "type": "object",
      "required": ["id", "name", "actions"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Unique stage identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable stage name"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "condition": {
          "type": "string",
          "description": "JavaScript expression to evaluate before running stage"
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/action"
          }
        },
        "onSuccess": {
          "$ref": "#/definitions/stageCallback"
        },
        "onError": {
          "$ref": "#/definitions/stageCallback"
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Unique action identifier within stage"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "navigate",
            "click",
            "type",
            "screenshot",
            "wait",
            "evaluate",
            "extract",
            "skill",
            "condition",
            "loop",
            "http",
            "file",
            "search",
            "waitForSelector",
            "scroll",
            "select",
            "upload",
            "download",
            "custom"
          ],
          "description": "Action type"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "retry": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "timeout": {
          "type": "integer",
          "minimum": 0
        },
        "params": {
          "type": "object",
          "description": "Action-specific parameters"
        },
        "selector": {
          "type": "string",
          "description": "CSS/XPath selector for element actions"
        },
        "skill": {
          "type": "string",
          "description": "Skill name to invoke"
        },
        "skillParams": {
          "type": "object",
          "description": "Parameters passed to skill"
        },
        "condition": {
          "type": "string",
          "description": "JavaScript expression for conditional execution"
        },
        "loop": {
          "$ref": "#/definitions/loopConfig"
        },
        "output": {
          "type": "string",
          "description": "Variable name to store action result"
        },
        "onSuccess": {
          "$ref": "#/definitions/actionCallback"
        },
        "onError": {
          "$ref": "#/definitions/actionCallback"
        }
      }
    },
    "loopConfig": {
      "type": "object",
      "required": ["count"],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "variable": {
          "type": "string",
          "description": "Loop iteration variable name"
        },
        "over": {
          "type": "array",
          "description": "Array to iterate over"
        },
        "until": {
          "type": "string",
          "description": "JavaScript expression - loop until true"
        },
        "delay": {
          "type": "integer",
          "minimum": 0,
          "description": "Delay between iterations in ms"
        }
      }
    },
    "skill": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source": {
          "type": "string",
          "description": "Skill source: local, npm, or remote"
        },
        "path": {
          "type": "string",
          "description": "Local path or npm package name"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "config": {
          "type": "object",
          "description": "Skill-specific configuration"
        }
      }
    },
    "variable": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object", "expression"]
        },
        "value": {},
        "description": {
          "type": "string"
        }
      }
    },
    "errorHandling": {
      "type": "object",
      "properties": {
        "retry": {
          "$ref": "#/definitions/retryConfig"
        },
        "fallback": {
          "type": "string",
          "description": "Fallback workflow to execute on failure"
        },
        "notify": {
          "$ref": "#/definitions/notificationConfig"
        }
      }
    },
    "retryConfig": {
      "type": "object",
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "delay": {
          "type": "integer",
          "minimum": 0,
          "description": "Delay between retries in ms"
        },
        "backoff": {
          "type": "string",
          "enum": ["none", "linear", "exponential"]
        },
        "on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Error types to retry on"
        }
      }
    },
    "notificationConfig": {
      "type": "object",
      "properties": {
        "on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["start", "success", "error", "progress"]
          }
        },
        "channel": {
          "type": "string",
          "enum": ["email", "webhook", "slack", "console"]
        },
        "config": {
          "type": "object"
        }
      }
    },
    "stageCallback": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": ["continue", "stop", "next", "retry", "fallback"]
        },
        "target": {
          "type": "string",
          "description": "Target stage/action ID for navigation"
        }
      }
    },
    "actionCallback": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": ["continue", "stop", "retry", "skip", "fallback"]
        },
        "target": {
          "type": "string",
          "description": "Target action ID for navigation"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
